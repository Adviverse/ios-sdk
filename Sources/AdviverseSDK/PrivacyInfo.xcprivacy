<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Privacy manifest for AdviverseSDK (Apple-required for third-party SDKs, esp.
      ad SDKs that access the IDFA / use required-reason APIs). Declares:
        - Tracking: the SDK can use the IDFA to attribute installs / personalize
          ads across apps, which Apple defines as tracking.
        - Collected data: the device identifiers the SDK sends to the ad engine.
        - Required-reason API: UserDefaults (persisting the SDK's own first-party id).
    -->

    <!-- The SDK engages in tracking (IDFA-based attribution / cross-app ads). -->
    <key>NSPrivacyTracking</key>
    <true/>

    <!--
      Domains that receive data used for tracking. iOS BLOCKS these when the user
      hasn't granted ATT.

      Intentionally EMPTY. The SDK sends the IDFA (the only cross-app tracking
      identifier) ONLY when AppTrackingTransparency is authorized (see
      currentIdentity() -> attAuthorized() in Adviverse.swift). Without consent it
      sends lmt=1, no IDFA, and only an app-scoped first-party id for in-app
      frequency capping — i.e. no tracking data leaves the device. The ad-serving
      host (serve.adviverse.com) therefore does not collect tracking data absent
      consent, so it is not listed here; listing it would have iOS block the
      connection under ATT-denied and stop legitimate contextual (IDFA-free) ad
      serving. If you later add a dedicated measurement host that fires only with
      consent, add it here.
    -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- Data the SDK collects. Device IDs (IDFA + IDFV) sent to the engine. -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array>
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeDeviceID</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <true/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeThirdPartyAdvertising</string>
            </array>
        </dict>
    </array>

    <!-- Required-reason API usage. -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <dict>
            <!-- UserDefaults: persist the SDK's own first-party id (app-scoped). -->
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
